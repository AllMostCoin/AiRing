# Google AI (Gemini) API key — obtain from https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Google AI model to use (e.g. gemini-1.5-pro, gemini-2.0-flash)
GOOGLE_AI_MODEL=gemini-1.5-pro

# xAI (Grok) API key — obtain from https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# xAI Grok model to use (e.g. grok-3-fast, grok-3, grok-3-mini)
XAI_MODEL=grok-3-fast
