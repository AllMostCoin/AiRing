# AI API Keys — copy this file to .env and fill in your keys
# The app works in demo mode (simulated responses) without any keys.
# Each key activates real API calls for the corresponding character.

# ── Cloud (GPT-4.1) ────────────────────────────────────────────
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Barret (Claude Sonnet) ─────────────────────────────────────
# Get key at: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=

# ── Red XIII (Gemini 2.5 Flash) ────────────────────────────────
# Get key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ── Cid (Mistral Large) ────────────────────────────────────────
# Get key at: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# ── Tifa (GitHub Copilot via GitHub Models) ────────────────────
# Create a token at: https://github.com/settings/tokens
# Required permission: "Models" read access (under "AI models")
GITHUB_TOKEN=

# ── Vincent (Grok 3 mini via xAI) ─────────────────────────────
# Get key at: https://console.x.ai/
XAI_API_KEY=

# ── Yuffie (Ollama — free local inference) ─────────────────────
# Install Ollama: https://ollama.com  then: ollama pull llama3.2
OLLAMA_MODEL=
OLLAMA_BASE_URL=http://localhost:11434



# ── Solana RPC (optional — defaults to public mainnet) ─────────
# Use a private RPC for higher rate limits (e.g. Helius, QuickNode, Alchemy)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ── Social Signal Sources (optional — enable market sentiment scanning) ────
# CryptoPanic: aggregates crypto news + social mentions (free signup at cryptopanic.com)
CRYPTOPANIC_API_KEY=

# X.com / Twitter API v2 bearer token (requires Basic plan at developer.twitter.com)
# Used to search recent tweets for tracked token cashtags ($SOL, $BONK, etc.)
TWITTER_BEARER_TOKEN=

# Telegram Bot token — create a bot via @BotFather and add it to your channels
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram channel IDs the bot has been added to (e.g. -1001234567890)
TELEGRAM_CHANNEL_IDS=

# ── Server port (default: 3000) ────────────────────────────────
PORT=3000
