# AI API Keys — copy this file to .env and fill in your keys
# The app works in demo mode (simulated responses) without any keys.
# Each key activates real API calls for the corresponding character.

# ── Terra (GPT-4o) ─────────────────────────────────────────────
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Celes (Claude 3.5 Sonnet) ──────────────────────────────────
# Get key at: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=

# ── Locke (Gemini 2.0 Flash) ───────────────────────────────────
# Get key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ── Edgar (Mistral Large) ──────────────────────────────────────
# Get key at: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# ── Setzer (GitHub Copilot via GitHub Models) ──────────────────
# Create a token at: https://github.com/settings/tokens
# Required permission: "Models" read access (under "AI models")
GITHUB_TOKEN=

# ── Vincent (Grok 3 mini via xAI) ─────────────────────────────
# Get key at: https://console.x.ai/
XAI_API_KEY=

# ── Yuffie (Ollama — free local inference) ─────────────────────
# Ollama runs AI models locally on your machine — 100% free, no cloud account needed.
# Install: https://ollama.com | then run: ollama pull llama3.2
# Set OLLAMA_MODEL to activate Yuffie (e.g. llama3.2, phi3, mistral, gemma2, qwen2.5).
# Set OLLAMA_BASE_URL if Ollama runs on a different host (default: http://localhost:11434).
OLLAMA_MODEL=
OLLAMA_BASE_URL=

# ── Server port (default: 3000) ────────────────────────────────
PORT=3000
