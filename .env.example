# AI API Keys - copy this file to .env and fill in your keys
# The app works in demo mode without any keys

# OpenAI (GPT-4)
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google (Gemini)
GOOGLE_API_KEY=

# Mistral AI
MISTRAL_API_KEY=

# GitHub Copilot (GitHub Models — requires a GitHub token with model permissions)
# https://github.com/settings/tokens
GITHUB_TOKEN=

# Server port (default: 3000)
PORT=3000
