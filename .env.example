# AI API Keys — copy this file to .env and fill in your keys
# The app works in demo mode (simulated responses) without any keys.
# Each key activates real API calls for the corresponding character.

# ── Terra (GPT-4o) ─────────────────────────────────────────────
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Celes (Claude 3.5 Sonnet) ──────────────────────────────────
# Get key at: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=

# ── Locke (Gemini 2.0 Flash) ───────────────────────────────────
# Get key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ── Edgar (Mistral Large) ──────────────────────────────────────
# Get key at: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# ── Setzer (GitHub Copilot via GitHub Models) ──────────────────
# Create a token at: https://github.com/settings/tokens
# Required permission: "Models" read access (under "AI models")
GITHUB_TOKEN=

# ── Vincent (Grok 3 mini via xAI) ─────────────────────────────
# Get key at: https://console.x.ai/
XAI_API_KEY=

# ── Yuffie (OpenClaw — OpenAI-compatible local gateway) ────────
# OpenClaw is a self-hosted AI gateway — you must run it yourself.
# Get your ck_ token from your OpenClaw instance: https://openclaw.ai
# Set OPENCLAW_BASE_URL to your gateway's URL (e.g. http://my-server:18789)
# If not set, the app defaults to http://localhost:18789.
# NOTE: users can also configure the gateway URL in the browser settings panel.
# Set OPENCLAW_MODEL to your agent target (default: openclaw)
OPENCLAW_API_KEY= ck_wfz4XTVlyHhdmPDujrNc
OPENCLAW_BASE_URL= https://connect.composio.dev/mcp
OPENCLAW_MODEL=

# ── Server port (default: 3000) ────────────────────────────────
PORT=3000
