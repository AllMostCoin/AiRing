# =============================================================================
# APPLICATION
# =============================================================================
# The display name of the application
APP_NAME=AiRing

# Runtime environment: development | staging | production
APP_ENV=development

# Port the HTTP server listens on (default: 3000)
APP_PORT=3000

# =============================================================================
# AI PROVIDER API KEYS
# =============================================================================
# OpenAI API key — obtain from https://platform.openai.com/account/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Model to use for OpenAI requests (e.g. gpt-4o, gpt-4-turbo, gpt-3.5-turbo)
OPENAI_MODEL=gpt-4o

# Anthropic (Claude) API key — obtain from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Anthropic model to use (e.g. claude-3-5-sonnet-20241022)
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Google AI (Gemini) API key — obtain from https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=AIzaSyD0A-EVZIKsK8Or-9_-WCGaWolX46Mos2s

# Google AI model to use (e.g. gemini-1.5-pro)
GOOGLE_AI_MODEL=gemini-1.5-pro

# =============================================================================
# DATABASE
# =============================================================================
# Full database connection URL.
# Examples:
#   PostgreSQL : postgresql://user:password@localhost:5432/airing
#   MySQL      : mysql://user:password@localhost:3306/airing
#   SQLite     : file:./dev.db
DATABASE_URL=your_database_url_here

# =============================================================================
# AUTHENTICATION
# =============================================================================
# Secret used to sign and verify JWT tokens.
# Use a long, random string — at least 32 characters recommended.
JWT_SECRET=your_jwt_secret_here

# Token expiry duration (e.g. 1h, 7d, 30d)
JWT_EXPIRES_IN=7d

# =============================================================================
# LOGGING & DEBUGGING
# =============================================================================
# Set to true to enable verbose debug output (do NOT enable in production)
DEBUG=false

# Log level: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info
